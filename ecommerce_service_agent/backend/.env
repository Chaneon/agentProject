# ============================================================
# 电商智能客服Agent - 环境变量配置
# ============================================================

# 应用
DEBUG=True
SECRET_KEY=your-secret-key

# MySQL（主系统数据库，只读）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ecommerce_user
MYSQL_PASSWORD=ecommerce_pass
MYSQL_DATABASE=ecommerce_cs

# Redis（与主系统共用，读Session）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SESSION_PREFIX=session:

# Milvus（Agent独立使用）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_PRODUCT_COLLECTION=product_vectors
MILVUS_FAQ_COLLECTION=faq_vectors
MILVUS_MEMORY_COLLECTION=memory_summary_vectors

# LLM
LLM_PROVIDER=openai_compatible
LLM_APP_KEY=sk-xxxxxx
LLM_APP_ID=personal_use
LLM_BASE_URL=https://apihub.agnes-ai.com
LLM_MODEL=agnes-2.0-flash
LLM_TEMPERATURE=0.1

# Embedding
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 业务配置
SESSION_TTL_SECONDS=1800
MAX_SHORT_TERM_MESSAGES=20
TRANSFER_QUEUE_KEY=transfer:queue