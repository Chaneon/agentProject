# 大模型API
LLM_PROVIDER=openai_compatible
LLM_APP_KEY=sk-xxxxxx
LLM_APP_ID=personal_use
LLM_BASE_URL=https://apihub.agnes-ai.com
LLM_MODEL=agnes-2.0-flash
LLM_TEMPERATURE=0.1

# MySQL 数据库（与Java系统共用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=legal_agent
MYSQL_PWD=123546
MYSQL_DATABASE=legal_agent

# Redis（与Java系统共用，存储session）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PWD=
REDIS_DB=0

# Milvus 向量数据库
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# NL2SQL 执行限制
SQL_EXECUTOR_TIMEOUT=10
SQL_MAX_ROW=1000

# 重排模型（HuggingFace 模型名或路径）
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
# 向量化模型（用于生成 embedding）
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5